{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cathygo.local/schemas/cgo.knowledge-map.manifest.v1.json",
  "title": "CathyGO Knowledge Map Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "kind",
    "id",
    "title",
    "version",
    "owner",
    "visibility",
    "source_type",
    "assets"
  ],
  "properties": {
    "schema": {
      "const": "cgo.knowledge-map.manifest.v1"
    },
    "kind": {
      "const": "knowledge_map"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "legacy_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string"
    },
    "curriculum": {
      "type": "string"
    },
    "owner": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "type": {
          "enum": ["official", "user", "shared", "local"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "visibility": {
      "enum": ["public", "private", "shared", "draft"]
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "assets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "source_path": {
                "type": "string"
              },
              "bytes": {
                "type": "integer",
                "minimum": 0
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "task_links": {
      "type": "object"
    },
    "overlays": {
      "type": "object"
    },
    "generated_at": {
      "type": "string"
    }
  }
}
