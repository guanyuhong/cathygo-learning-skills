{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cathygo.local/schemas/cgo.learning_pack.v1.schema.json",
  "title": "CathyGO Learning Pack",
  "type": "object",
  "required": ["schema", "kind", "id", "title", "version", "subject", "stage", "kg_refs", "objectives", "tasks", "review"],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "cgo.learning_pack.v1" },
    "kind": { "const": "learning_pack" },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "language": { "type": "string" },
    "subject": { "type": "string", "minLength": 1 },
    "stage": { "type": "string", "minLength": 1 },
    "grade_band": { "type": "string" },
    "source_refs": { "type": "array" },
    "kg_refs": { "type": "array" },
    "objectives": { "type": "array" },
    "knowledge_context": { "type": "object" },
    "tasks": { "type": "array" },
    "misconceptions": { "type": "array" },
    "remediations": { "type": "array" },
    "assessment": { "type": "array" },
    "compat": { "type": "object" },
    "review": { "type": "object" }
  }
}
